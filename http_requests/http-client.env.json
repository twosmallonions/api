{
  "dev": {
    "Security": {
      "Auth": {
        "oidc": {
          "Type": "OAuth2",
          "Grant Type": "Authorization Code",
          "Client Credentials": "basic",
          "Client ID": "{{client_id}}",
          "Client Secret": "{{client_secret}}",
          "PKCE": true,
          "Token URL": "{{token_url}}",
          "Auth URL": "{{auth_url}}",
          "Scope": "openid tso_api minio_user_read",
          "Redirect URL": "http://localhost:4567"
        }
      }
    }
  }
}